# МебельГрад КИС - Пример конфигурации
# Копируйте этот файл как .env и заполните значения

# База данных
DATABASE_URL=postgresql://postgres:password@localhost:5432/mebelgrad_kis

# Секретные ключи (измените на production)
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production

# Окружение
FLASK_ENV=development
# Используйте: development, testing, production

# Flask конфигурация
FLASK_DEBUG=True
FLASK_APP=run.py

# Логирование
LOG_LEVEL=INFO
